<Window x:Class="OpenCvWpfTracking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenCvWpfTracking"    
        mc:Ignorable="d"
        Title="TORUSS [EO/IR] DEMO VIEWER" 
        Height="1080"
        Width="1920">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1.15*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- 상단 영역 -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 큰 영상 -->
            <Border Grid.Column="0"
                    Margin="0,0,15,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                <Grid>
                    <!-- 영상 출력 -->
                    <Image Source="{Binding EOCameraImage}"
                           Stretch="Uniform"/>
                    <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                    <TextBlock Text="{Binding EoStatusText}"
                               Margin="0,0,10,5"
                               Foreground="#00E676"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- 우측 작은 영상 2개 -->
            <Grid Grid.Column="1" Margin="0,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                    <Grid>
                        <!-- 영상 출력 -->
                        <Image Source="{Binding IRCameraImage}"
                           Stretch="Uniform"/>
                        <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                        <TextBlock Text="{Binding IrStatusText}"
                                   Margin="0,0,10,5"
                                   Foreground="#FF7043"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                    <Grid>
                        <!-- 영상 출력 -->
                        <Image Source="{Binding CameraImage}"
                           Stretch="Uniform"/>
                        <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                        <TextBlock Text="{Binding VdStatusText}"
                                   Margin="0,0,10,5"
                                   Foreground="#4FC3F7"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 우측 제어 패널 -->
            <Border Grid.Column="2"
                    Background="#646A71"
                    BorderBrush="#8B949E"
                    BorderThickness="2"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="50" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 연결 해제 -->
                    <Button Grid.Row="0"
                            Height="34"
                            Margin="0,0,0,12"
                            Content="연결 해제"
                            Background="#6E7F68"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding DisconnectCommand}"/>

                    <!-- 장비 연결 버튼 -->
                    <Button Grid.Row="1"
                            Height="34"
                            Width="130"
                            HorizontalAlignment="Left"
                            Content="장비 연결"
                            Background="#466A87"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding ConnectCommand}"/>

                    <!-- 장비 리스트 -->
                    <Border Grid.Row="3"
                            Margin="0,10,0,0"
                            Background="#5F666D"
                            BorderBrush="#95A5B0"
                            BorderThickness="1.5"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="장비 연결"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1">
                                <RadioButton Content="연결 해제"
                                             Foreground="#6EC1FF"
                                             FontSize="15"
                                             Margin="0,5"/>

                                <RadioButton Content="TORUSS-LR1000"
                                             Foreground="#6EC1FF"
                                             FontSize="15"
                                             Margin="0,5"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
