<Window x:Class="OpenCvWpfTracking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenCvWpfTracking"    
        mc:Ignorable="d"
        Title="TORUSS [EO/IR] DEMO VIEWER" 
        Height="1080"
        Width="1920">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1.15*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- 상단 영역 -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 큰 영상 -->
            <Border Grid.Column="0"
                    Margin="0,0,15,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                <Grid>
                    <!-- 영상 출력 -->
                    <Image Source="{Binding EOCameraImage}"
                           Stretch="Uniform"/>
                    <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                    <TextBlock Text="{Binding EoStatusText}"
                               Margin="0,0,10,5"
                               Foreground="#00E676"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- 우측 작은 영상 2개 -->
            <Grid Grid.Column="1" Margin="0,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                    <Grid>
                        <!-- 영상 출력 -->
                        <Image Source="{Binding IRCameraImage}"
                           Stretch="Uniform"/>
                        <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                        <TextBlock Text="{Binding IrStatusText}"
                                   Margin="0,0,10,5"
                                   Foreground="#FF7043"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                    <Grid>
                        <!-- 영상 출력 -->
                        <Image Source="{Binding VDCameraImage}"
                           Stretch="Uniform"/>
                        <!-- 안내 문자 (오른쪽 하단에 보이게) -->
                        <TextBlock Text="{Binding VdStatusText}"
                                   Margin="0,0,10,5"
                                   Foreground="#4FC3F7"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 우측 제어 패널 -->
            <Border Grid.Column="2"
                    Background="#646A71"
                    BorderBrush="#8B949E"
                    BorderThickness="2"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="50" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 연결 해제 -->
                    <Button Grid.Row="0"
                            Height="34"
                            Margin="0,0,0,5"
                            Content="연결 해제"
                            Background="#6E7F68"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding DisconnectCommand}"/>

                    <!-- 장비 연결 버튼 -->
                    <Button Grid.Row="1"
                            Height="34"
                            Width="130"
                            HorizontalAlignment="Left"
                            Content="장비 연결"
                            Background="#466A87"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding ConnectCommand}"/>

                    <!-- 장비 리스트 -->
                    <Border Grid.Row="3"
                            Background="#5F666D"
                            BorderBrush="#95A5B0"
                            BorderThickness="1.5"
                            Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- 제목 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 장비 리스트 -->
                                <RowDefinition Height="*"/>
                                <!-- [PT] / [ZOOM] / [FOCUS] / [LRF] 제어 영역 -->
                                <!--<RowDefinition Height="100"/>-->
                            </Grid.RowDefinitions>

                            <TextBlock Text="장비 연결"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            <!-- 제어 패널 Scroll 영역 -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="0,0,0,10"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Vertical" 
                                            Margin="0,0,0,10">
                                    <!-- 테스트용 장비 선택 RadioButton 
                                         현재는 단일 장비 연결 구조로 사용하므로
                                         임시 비활성화 처리.
                                         추후 다중 장비 선택 기능 추가 시 재사용 예정 -->
                                    <!--<RadioButton Content="연결 해제"
                                                 Foreground="#6EC1FF"
                                                 FontSize="15"
                                                 Margin="0,5"/>
                                    
                                    <RadioButton Content="TORUSS-LR1000"
                                                 Foreground="#6EC1FF"
                                                 FontSize="15"
                                                 Margin="0,5"/>-->

                                    <!-- [PAN] / [TILT] 제어 -->
                                    <Border Grid.Row="2"
                                            Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 제목 -->
                                            <TextBlock Text="PAN / TILT CONTROL"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>

                                            <!-- [PT] 방향키 제어 버튼 영역 -->
                                            <Grid Grid.Row="1"
                                                  Width="120"
                                                  Height="120"
                                                  HorizontalAlignment="Center">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <!-- [TILT] [UP] -->
                                                <Button Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="5"
                                                        FontSize="18"
                                                        Content="▲"
                                                        PreviewMouseDown="TiltUp_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [PAN] [LEFT] -->
                                                <Button Grid.Row="1"
                                                        Grid.Column="0"
                                                        Margin="5"
                                                        FontSize="18"
                                                        Content="◀"
                                                        PreviewMouseDown="PanLeft_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- 중앙 표시 -->
                                                <Border Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="3"
                                                        Background="#3F454B"
                                                        BorderBrush="#8B949E"
                                                        BorderThickness="1">
                                                    <TextBlock Text="PT"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- [PAN] [RIGHT] -->
                                                <Button Grid.Row="1"
                                                        Grid.Column="2"
                                                        Margin="5"
                                                        FontSize="18"
                                                        Content="▶"
                                                        PreviewMouseDown="PanRight_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [TILT] [DOWN] -->
                                                <Button Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5"
                                                        FontSize="18"
                                                        Content="▼"
                                                        PreviewMouseDown="TiltDown_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>
                                            </Grid>

                                            <!-- 이동 단위 표시 -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding PanTiltSpeedLevel,StringFormat=PT SPEED LV : {0}}"
                                                       Foreground="#D0D7DE"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- [ZOOM] / [FOCUS] 제어 -->
                                    <Border Grid.Row="2"
                                            Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 제목 -->
                                            <TextBlock Text="ZOOM / FOCUS CONTROL"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>

                                            <!-- [ZOOM] 제어 -->
                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10">

                                                <!-- [ZOOM] 확대 -->
                                                <Button Content="ZOOM +"
                                                        Width="85"
                                                        Height="30"
                                                        Margin="5"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        PreviewMouseDown="ZoomIn_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [ZOOM] 축소 -->
                                                <Button Content="ZOOM -"
                                                        Width="85"
                                                        Height="30"
                                                        Margin="5"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        PreviewMouseDown="ZoomOut_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                            </StackPanel>

                                            <!-- [FOCUS] 제어 -->
                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10">

                                                <!-- [FOCUS] [Far] -->
                                                <Button Content="FOCUS +"
                                                        Width="85"
                                                        Height="30"
                                                        Margin="5"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        PreviewMouseDown="FocusFar_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [FOCUS] [Near] -->
                                                <Button Content="FOCUS -"
                                                        Width="85"
                                                        Height="30"
                                                        Margin="5"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        PreviewMouseDown="FocusNear_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                    <!-- [LRF] 제어 -->
                                    <Border Grid.Row="2"
                                            Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 제목 -->
                                            <TextBlock Text="LRF CONTROL"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8"/>

                                            <!-- [LRF] 1회 거리 측정 -->
                                            <Button Grid.Row="1"
                                                    Content="MEASURE"
                                                    Width="180"
                                                    Height="32"
                                                    Margin="5"
                                                    FontWeight="Bold"
                                                    HorizontalAlignment="Center"
                                                    Command="{Binding }"/>

                                            <!-- 추후 거리값 표시 영역 -->
                                            <TextBlock Grid.Row="2"
                                                       Text="DISTANCE : - m"
                                                       Foreground="#D0D7DE"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,0"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                        </Grid>
                    </Border>

                </Grid>
            </Border>

        </Grid>

    </Grid>
</Window>
